{
  "source": {
    "include": ["js"],
    "includePattern": ".+\\.js$",
    "excludePattern": "(^|/|\\\\)(node_modules|generated-docs|tests)(/|\\\\)"
  },
  "plugins": ["plugins/markdown"],
  "opts": {
    "destination": "./generated-docs/reference",
    "encoding": "utf8",
    "recurse": true,
    "readme": "./README.md"
  },
  "templates": {
    "default": {
      "includeDate": false,
      "outputSourceFiles": true
    }
  }
}
