@startuml
title Information System for Dental Clinic Management - Component Diagram
left to right direction
skinparam componentStyle rectangle
skinparam packageStyle rectangle

actor Patient
actor Administrator
actor Doctor
actor Cashier

package "Client Layer" {
  [Web UI] as WebUI
}

package "Application Layer" {
  [Authentication / RBAC] as Auth
  [Patient Management] as PatientMgmt
  [Appointment Scheduling] as Scheduling
  [Treatment Records] as Records
  [Payment / Accounting] as Billing
  [Reporting / Administration] as Reporting
  [Notification Service] as Notification
}

database "Clinic Database" as DB

Patient --> WebUI : requests appointments\nviews reminders
Administrator --> WebUI : manages patients\nand schedules
Doctor --> WebUI : reviews visits\nupdates treatment notes
Cashier --> WebUI : records payments

WebUI --> Auth
WebUI --> PatientMgmt
WebUI --> Scheduling
WebUI --> Records
WebUI --> Billing
WebUI --> Reporting

Auth --> DB : users / roles
PatientMgmt --> DB : patient profiles
Scheduling --> DB : appointments
Scheduling --> Notification : reminders
Records --> DB : medical history
Records --> PatientMgmt : patient context
Billing --> DB : invoices / payments
Billing --> Scheduling : completed visit context
Reporting --> DB : aggregates / reports
Reporting --> Auth : access control checks
Notification --> DB : reminder templates\nand delivery status

@enduml
